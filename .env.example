# ==============================================================
# .env.example — Production template for Render deployment
# Copy this to .env for local development and fill in values.
# NEVER commit .env to version control.
# ==============================================================

# --------------------------------------------------------------
# Application
# --------------------------------------------------------------
APP_NAME="Crypto Exchange"
APP_ENV=production
APP_KEY=                          # Required: run `php artisan key:generate --show`
APP_DEBUG=false
APP_URL=https://your-app.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# --------------------------------------------------------------
# Logging
# On Render, stderr is captured by the log aggregator.
# Use "single" if you prefer a file inside storage/logs/.
# --------------------------------------------------------------
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --------------------------------------------------------------
# Database — External MySQL (e.g. PlanetScale, Aiven, Railway)
# On Render: add these as Environment Variables, NOT here.
# --------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=                          # e.g. mysql.render.com or your external host
DB_PORT=3306
DB_DATABASE=                      # your database name
DB_USERNAME=                      # your database username
DB_PASSWORD=                      # your database password
# DB_URL=                         # Alternative: full DSN (overrides above)

# Optional: SSL certificate for hosted MySQL (PlanetScale requires this)
# MYSQL_ATTR_SSL_CA=/etc/ssl/certs/ca-certificates.crt

# --------------------------------------------------------------
# Cache — database driver (no Redis required)
# --------------------------------------------------------------
CACHE_STORE=database

# --------------------------------------------------------------
# Queue — database driver (processed by Supervisor worker)
# --------------------------------------------------------------
QUEUE_CONNECTION=database

# --------------------------------------------------------------
# Session — database driver
# --------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# --------------------------------------------------------------
# Container / Render-specific
# --------------------------------------------------------------
# PORT is injected automatically by Render — do NOT set it here.
# PORT=8080

# Set to "true" to run `php artisan migrate --force` on startup
RUN_MIGRATIONS=false

# Set to "true" to wait for DB before booting (useful on cold starts)
WAIT_FOR_DB=true

# --------------------------------------------------------------
# Broadcast
# --------------------------------------------------------------
BROADCAST_CONNECTION=log

# --------------------------------------------------------------
# Filesystem
# --------------------------------------------------------------
FILESYSTEM_DISK=local

# For S3-compatible storage (e.g. Cloudflare R2, AWS S3):
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# --------------------------------------------------------------
# Mail
# Use a transactional email service in production (Mailgun, SES, etc.)
# --------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Example — Mailgun:
# MAIL_MAILER=mailgun
# MAILGUN_DOMAIN=mg.your-domain.com
# MAILGUN_SECRET=key-xxxxxxxxxxxx

# Example — Amazon SES:
# MAIL_MAILER=ses
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# --------------------------------------------------------------
# Redis (optional — not required; app uses database driver)
# Only needed if you switch CACHE_STORE or QUEUE_CONNECTION to redis
# --------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --------------------------------------------------------------
# Vite (build-time only — not used at runtime)
# --------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
