# ==============================================================
# .dockerignore — excludes files from the Docker build context
# Keeps the image lean and prevents secrets leaking into layers
# ==============================================================

# --- Version control ---
.git
.gitignore
.gitattributes

# --- Node / npm ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- PHP / Composer ---
vendor/

# --- Laravel generated / runtime files ---
bootstrap/cache/*.php
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
storage/logs/*.log
storage/app/public/*

# --- Environment & secrets ---
.env
.env.*
!.env.example

# --- Docker root files (not needed inside the image) ---
Dockerfile
docker-compose*.yml
.dockerignore
# NOTE: docker/ directory is intentionally NOT excluded — the Dockerfile
# COPYs config files from docker/nginx/, docker/php/, etc. into the image.

# --- Tests ---
tests/
phpunit.xml
phpunit.xml.dist
.phpunit.result.cache
coverage/

# --- Development tooling ---
.editorconfig
.php-cs-fixer.cache
.pint.cache
.prettierrc
.eslintrc*
.stylelintrc*

# --- IDE / OS ---
.idea/
.vscode/
*.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- CI ---
.github/
.gitlab-ci.yml
.travis.yml
.circleci/

# --- Docs ---
README.md
CHANGELOG.md
LICENSE
*.md

# --- Misc build artifacts ---
*.zip
*.tar.gz
*.sql
public/hot
